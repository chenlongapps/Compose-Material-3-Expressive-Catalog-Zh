    <string name="component_adaptive_name">自适应布局</string>
    <string name="component_adaptive_description">自适应脚手架会根据不同的窗口尺寸类别和设备姿态自动调整布局。\n\n注意：建议在可调整尺寸的模拟器或折叠屏设备上体验此示例。</string>
    <string name="component_badge_name">徽标</string>
    <string name="component_badge_description">徽标可显示动态信息，例如新通知或待处理请求数量。徽标可以只包含图标，也可以包含简短文字。</string>
    <string name="component_bottom_app_bar_name">底部应用栏</string>
    <string name="component_bottom_app_bar_description">底部应用栏在移动设备屏幕底部显示导航和关键操作。</string>
    <string name="component_bottom_sheet_name">底部工作表</string>
    <string name="component_bottom_sheet_description">底部工作表是固定在屏幕底部、用于承载补充内容的表面。</string>
    <string name="component_buttons_name">按钮</string>
    <string name="component_buttons_description">按钮帮助用户发起操作，例如发送电子邮件、共享文档或点赞帖子。</string>
    <string name="component_button_groups_name">按钮组</string>
    <string name="component_button_groups_description">按钮组是 Material 组件的容器，可在按下时添加动画效果。</string>
    <string name="component_card_name">卡片</string>
    <string name="component_card_description">卡片包含与某个主题相关的内容和操作。</string>
    <string name="component_carousel_name">轮播</string>
    <string name="component_carousel_description">轮播是一种样式化列表，其浏览方式适合大幅图片和其他视觉内容丰富的场景。</string>
    <string name="component_checkboxes_name">复选框</string>
    <string name="component_checkboxes_description">复选框允许用户从一组选项中选择一个或多个项目，或开启、关闭某个选项。</string>
    <string name="component_chips_name">信息块</string>
    <string name="component_chips_description">信息块允许用户输入信息、进行选择、筛选内容或触发操作。</string>
    <string name="component_date_pickers_name">日期选择器</string>
    <string name="component_date_pickers_description">日期选择器允许用户选择一个日期或日期范围。</string>
    <string name="component_dialogs_name">对话框</string>
    <string name="component_dialogs_description">对话框在用户流程中提供重要提示，可要求执行操作、传达信息或帮助用户完成任务。</string>
    <string name="component_extended_fab_name">扩展 FAB</string>
    <string name="component_extended_fab_description">扩展 FAB 帮助用户执行主要操作。它比普通 FAB 更宽，可容纳文字标签并提供更大的触控区域。</string>
    <string name="component_fab_name">悬浮操作按钮</string>
    <string name="component_fab_description">FAB 代表屏幕上最重要的操作，让关键操作触手可及。</string>
    <string name="component_fab_menu_name">FAB 菜单</string>
    <string name="component_fab_menu_description">点击 FAB 时，FAB 菜单会显示其他关键操作。</string>
    <string name="component_floating_toolbar_name">悬浮工具栏</string>
    <string name="component_floating_toolbar_description">悬浮工具栏在内容上方显示关键操作。</string>
    <string name="component_icon_buttons_name">图标按钮</string>
    <string name="component_icon_buttons_description">图标按钮允许用户通过一次点按执行操作和做出选择。</string>
    <string name="component_lists_name">列表</string>
    <string name="component_lists_description">列表是由文字或图片组成的连续纵向索引。</string>
    <string name="component_loading_indicators_name">加载指示器</string>
    <string name="component_loading_indicators_description">加载指示器表示不确定的等待时间，或显示加载过程的进度。</string>
    <string name="component_menus_name">菜单</string>
    <string name="component_menus_description">菜单在临时表面上显示一组选项。</string>
    <string name="component_navigation_bar_name">导航栏</string>
    <string name="component_navigation_bar_description">导航栏为切换应用中的主要目的地提供持久且便捷的方式。</string>
    <string name="component_navigation_drawer_name">导航抽屉</string>
    <string name="component_navigation_drawer_description">导航抽屉以符合人体工学的方式提供应用目的地入口。</string>
    <string name="component_navigation_rail_name">导航轨道</string>
    <string name="component_navigation_rail_description">在平板和桌面屏幕上，导航轨道提供主要目的地入口。</string>
    <string name="component_navigation_suite_name">导航套件脚手架</string>
    <string name="component_navigation_suite_description">导航套件脚手架会包装提供的内容，并根据当前 NavigationSuiteType 显示合适的导航组件。\n\n注意：建议在可调整尺寸的模拟器或折叠屏设备上体验此示例。</string>
    <string name="component_progress_indicators_name">进度指示器</string>
    <string name="component_progress_indicators_description">进度指示器表示不确定的等待时间，或显示某个过程的进度。</string>
    <string name="component_pull_to_refresh_name">下拉刷新指示器</string>
    <string name="component_pull_to_refresh_description">下拉刷新是列表、网格列表和卡片集合顶部可用的滑动手势，用于获取最新内容。</string>
    <string name="component_radio_buttons_name">单选按钮</string>
    <string name="component_radio_buttons_description">单选按钮允许用户从一组选项中选择一项。</string>
    <string name="component_search_bars_name">搜索栏</string>
    <string name="component_search_bars_description">搜索栏允许用户输入关键词或短语并获取相关信息。</string>
    <string name="component_segmented_button_name">分段按钮</string>
    <string name="component_segmented_button_description">分段按钮帮助用户选择选项、切换视图或排序元素。</string>
    <string name="component_toggle_buttons_name">切换按钮</string>
    <string name="component_toggle_buttons_description">切换按钮可被选中，并在按下时播放动画。</string>
    <string name="component_sliders_name">滑块</string>
    <string name="component_sliders_description">滑块允许用户从一个数值范围中进行选择。</string>
    <string name="component_snackbars_name">Snackbar</string>
    <string name="component_snackbars_description">Snackbar 在屏幕底部简短显示有关应用进程的消息。</string>
    <string name="component_split_button_name">拆分按钮</string>
    <string name="component_split_button_description">拆分按钮允许用户在主要操作之外执行其他操作。</string>
    <string name="component_switches_name">开关</string>
    <string name="component_switches_description">开关用于开启或关闭单项设置。</string>
    <string name="component_tabs_name">标签页</string>
    <string name="component_tabs_description">标签页用于组织不同屏幕、数据集和交互中的内容。</string>
    <string name="component_text_fields_name">文本字段</string>
    <string name="component_text_fields_description">文本字段允许用户输入和编辑文字。</string>
    <string name="component_tooltips_name">工具提示</string>
    <string name="component_tooltips_description">工具提示用于将用户注意力引导到锚点组件。</string>
    <string name="component_time_picker_name">时间选择器</string>
    <string name="component_time_picker_description">时间选择器允许用户选择一天中的某个时间。</string>
    <string name="component_top_app_bar_name">顶部应用栏</string>
    <string name="component_top_app_bar_description">顶部应用栏在屏幕顶部显示信息和操作。</string>
    <string name="component_material_shapes_name">Material 形状</string>
    <string name="component_material_shapes_description">Material 形状用于定义组件的外形。</string>
    <string name="component_swipe_to_dismiss_name">滑动关闭</string>
    <string name="component_swipe_to_dismiss_description">滑动关闭是一种用于移除列表项目的手势。</string>
